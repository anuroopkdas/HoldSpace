<UserControl x:Class="HoldSpace.Views.TriggerSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HoldSpace.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="700"
             Background="#0C0C0D">
    
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Trigger Configuration" Foreground="#F3F3F3" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="Configure trigger activation hotkeys and timing delay thresholds." Foreground="#8E8E93" FontSize="12" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Content Area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="800" HorizontalAlignment="Stretch">
                
                <!-- Trigger Key Selection Card -->
                <Border Background="#131315" BorderBrush="#262629" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="ACTIVATION KEY" Foreground="#8E8E93" FontSize="11" FontWeight="Bold" Margin="0,0,0,16"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Trigger Key" Foreground="#F3F3F3" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="Hold this key to show the overlay" Foreground="#8E8E93" FontSize="11" Margin="0,4,0,0"/>
                            </StackPanel>

                            <Button x:Name="BtnRecord" Grid.Column="1" Content="Caps Lock" Width="140" Height="36" 
                                    Style="{StaticResource DefaultButtonStyle}" Foreground="#0A84FF" BorderBrush="#0A84FF"
                                    Click="BtnRecord_Click"/>
                        </Grid>

                        <!-- Recording Banner -->
                        <Border x:Name="RecordBanner" Background="#2A1E0D" BorderBrush="#FF9F0A" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,16,0,0" Visibility="Collapsed">
                            <TextBlock Text="Press any key on your keyboard to set it as the trigger..." Foreground="#FF9F0A" FontSize="12" TextAlignment="Center" FontWeight="SemiBold"/>
                        </Border>

                        <!-- Win Key Warning -->
                        <Border x:Name="WinKeyWarning" Background="#2C1616" BorderBrush="#FF453A" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,16,0,0" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="EXPERIMENTAL KEY WARNING" Foreground="#FF453A" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                <TextBlock Text="The Windows key is controlled by the operating system and may conflict with system shortcuts. Use a custom trigger key for the most reliable experience." 
                                           Foreground="#8E8E93" FontSize="11" TextWrapping="Wrap" LineHeight="16"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Hold Delay Slider Card -->
                <Border Background="#131315" BorderBrush="#262629" BorderThickness="1" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="HOLD TIME THRESHOLD" Foreground="#8E8E93" FontSize="11" FontWeight="Bold" Margin="0,0,0,16"/>
                        
                        <Grid>
                            <TextBlock Text="Hold Delay" Foreground="#F3F3F3" FontSize="14" FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock x:Name="TxtDelayValue" Text="120" Foreground="#0A84FF" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Text=" ms" Foreground="#8E8E93" FontSize="14"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Minimum duration the key must be held down to reveal the launcher overlay." Foreground="#8E8E93" FontSize="11" Margin="0,4,0,16"/>
                        
                        <Slider x:Name="SliderDelay" Minimum="50" Maximum="1000" Value="120" TickFrequency="10" IsSnapToTickEnabled="True"
                                ValueChanged="SliderDelay_ValueChanged" Margin="0,8,0,0"/>

                        <!-- Dynamic Delay Quip -->
                        <TextBlock x:Name="TxtDelayQuip" Text="A human blink takes about 100ms. Blink and you'll trigger it!" Foreground="#FF9F0A" FontSize="11" FontStyle="Italic" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
