<UserControl x:Class="HoldSpace.Views.AppearanceSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HoldSpace.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="700"
             Background="#0C0C0D">
    
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Appearance Options" Foreground="#F3F3F3" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="Customize overlay visuals, transparency, backdrop states, and motion." Foreground="#8E8E93" FontSize="12" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Form Panel -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="800" HorizontalAlignment="Stretch">
                
                <!-- Dim & Opacity Card -->
                <Border Background="#131315" BorderBrush="#262629" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="VISUAL EFFECTS" Foreground="#8E8E93" FontSize="11" FontWeight="Bold" Margin="0,0,0,16"/>

                        <!-- Dim Toggle -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="Dim Background" Foreground="#F3F3F3" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="Darken background windows during activation." Foreground="#8E8E93" FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" x:Name="CheckDim" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                      Checked="CheckDim_Checked" Unchecked="CheckDim_Unchecked"/>
                        </Grid>

                        <Border Height="1" Background="#262629" Margin="0,4,0,16"/>

                        <!-- Opacity Slider -->
                        <Grid>
                            <TextBlock Text="Backdrop Opacity" Foreground="#F3F3F3" FontSize="14" FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock x:Name="TxtOpacityValue" Text="80" Foreground="#0A84FF" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Text=" %" Foreground="#8E8E93" FontSize="14"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Control backdrop translucency and visibility when dimmed." Foreground="#8E8E93" FontSize="11" Margin="0,4,0,16"/>
                        <Slider x:Name="SliderOpacity" Minimum="20" Maximum="100" Value="80" TickFrequency="5" IsSnapToTickEnabled="True"/>
                    </StackPanel>
                </Border>

                <!-- Animation Speed Card -->
                <Border Background="#131315" BorderBrush="#262629" BorderThickness="1" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="MOTION &amp; ANIMATION" Foreground="#8E8E93" FontSize="11" FontWeight="Bold" Margin="0,0,0,16"/>

                        <Grid>
                            <TextBlock Text="Hover Animation Speed" Foreground="#F3F3F3" FontSize="14" FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock x:Name="TxtAnimValue" Text="150" Foreground="#0A84FF" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Text=" ms" Foreground="#8E8E93" FontSize="14"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Duration of card zoom and glow transitions when hovered." Foreground="#8E8E93" FontSize="11" Margin="0,4,0,16"/>
                        <Slider x:Name="SliderAnim" Minimum="50" Maximum="500" Value="150" TickFrequency="25" IsSnapToTickEnabled="True"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
