<UserControl x:Class="HoldSpace.Views.ProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="520" d:DesignWidth="720"
             Background="#0C0C0D">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Modes" Foreground="#F3F3F3" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="Create and switch between different shortcut layouts." Foreground="#8E8E93" FontSize="12" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Toolbar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="＋  New Mode" Style="{StaticResource AccentButtonStyle}" Click="BtnCreate_Click" Padding="16,8"/>
        </StackPanel>

        <!-- Modes List -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ProfilesList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#131315" BorderBrush="#262629" BorderThickness="1" CornerRadius="12"
                                Margin="0,0,0,10" Padding="20,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left: name, badge, stats -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" Foreground="#F3F3F3" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <!-- Active badge (shown via code-behind tag) -->
                                        <Border x:Name="ActiveBadge" Margin="10,0,0,0" Padding="8,2" CornerRadius="4"
                                                Background="#1A2D3C" BorderBrush="#0A84FF" BorderThickness="0.5"
                                                Visibility="Collapsed">
                                            <TextBlock Text="Active" Foreground="#0A84FF" FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock x:Name="ShortcutCount" Foreground="#8E8E93" FontSize="11" Margin="0,4,0,0"/>
                                </StackPanel>

                                <!-- Right: actions -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button x:Name="BtnSetActive" Content="Set Active" Style="{StaticResource DefaultButtonStyle}"
                                            Padding="10,6" Margin="4,0" Click="BtnSetActive_Click" Tag="{Binding Id}"/>
                                    <Button Content="Rename" Style="{StaticResource DefaultButtonStyle}"
                                            Padding="10,6" Margin="4,0" Click="BtnRename_Click" Tag="{Binding Id}"/>
                                    <Button Content="Duplicate" Style="{StaticResource DefaultButtonStyle}"
                                            Padding="10,6" Margin="4,0" Click="BtnDuplicate_Click" Tag="{Binding Id}"/>
                                    <Button Content="Delete" Style="{StaticResource DangerButtonStyle}"
                                            Padding="10,6" Margin="4,0,0,0" Click="BtnDelete_Click" Tag="{Binding Id}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
