<UserControl x:Class="HoldSpace.Views.CanvasEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HoldSpace.Views"
             xmlns:converters="clr-namespace:HoldSpace.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="850"
             Background="#0C0C0D">
    
    <UserControl.Resources>
        <converters:PercentageToAbsoluteConverter x:Key="PercentConverter"/>

        <!-- Styled Draggable Card for Editor -->
        <Style x:Key="EditorCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#131315"/>
            <Setter Property="BorderBrush" Value="#262629"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="80"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="6" ShadowDepth="1" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#3A3A3C"/>
                    <Setter Property="Background" Value="#1C1C1E"/>
                </Trigger>
                <!-- Selection outline and glow -->
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="BorderBrush" Value="#0A84FF"/>
                    <Setter Property="BorderThickness" Value="1.5"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#0A84FF" BlurRadius="8" ShadowDepth="1" Opacity="0.25"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <!-- Title, Subtitle & Top Toolbar Area -->
            <RowDefinition Height="Auto"/>
            <!-- Main Split Layout (Canvas | Inspector) -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Header & Toolbar Grid -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Page Title and Subtitle -->
            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Canvas Layout Editor" Foreground="#F3F3F3" FontSize="20" FontWeight="Bold"/>
                    <!-- Compact Mode Switcher -->
                    <Border Background="#131315" BorderBrush="#262629" BorderThickness="1" CornerRadius="8"
                            Padding="10,4" Margin="20,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Mode:" Foreground="#8E8E93" FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="ModeSwitcher" Width="140" FontSize="12"
                                      SelectionChanged="ModeSwitcher_SelectionChanged"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <TextBlock Text="Drag shortcuts to reposition them. Select a shortcut to edit its details." Foreground="#8E8E93" FontSize="12" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Top Toolbar Grid -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left Actions (Secondary Actions) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnAdd" Content="+ Add Shortcut" Style="{StaticResource DefaultButtonStyle}" Padding="12,8" Margin="0,0,8,0" Click="BtnAdd_Click"/>
                    <Button x:Name="BtnTest" Content="Test Overlay" Style="{StaticResource DefaultButtonStyle}" Padding="12,8" Click="BtnTest_Click"/>
                    
                    <!-- Snap Switch -->
                    <CheckBox x:Name="CheckSnap" Content="Snap to Grid" Style="{StaticResource ToggleSwitchStyle}" IsChecked="True" VerticalAlignment="Center" Margin="16,0,0,0" Checked="CheckSnap_Checked" Unchecked="CheckSnap_Unchecked"/>

                    <!-- Undo / Redo Buttons -->
                    <Button x:Name="BtnUndo" Content="Undo" Style="{StaticResource DefaultButtonStyle}" Padding="10,6" Margin="16,0,4,0" Click="BtnUndo_Click" IsEnabled="False"/>
                    <Button x:Name="BtnRedo" Content="Redo" Style="{StaticResource DefaultButtonStyle}" Padding="10,6" Click="BtnRedo_Click" IsEnabled="False"/>

                    <!-- Zoom Slider -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                        <TextBlock Text="Zoom:" Foreground="#8E8E93" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider x:Name="SliderZoom" Minimum="0.75" Maximum="1.25" Value="1.0" Width="90" VerticalAlignment="Center" ValueChanged="SliderZoom_ValueChanged" TickFrequency="0.25" IsSnapToTickEnabled="True"/>
                        <TextBlock x:Name="TxtZoomPct" Text="100%" Foreground="#8E8E93" FontSize="11" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Right Actions (Primary Actions) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtUnsavedStatus" Text="● Unsaved changes" Foreground="{StaticResource WarningBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,16,0" VerticalAlignment="Center" Visibility="Collapsed"/>
                    <Button x:Name="BtnResetLayout" Content="Reset Layout" Style="{StaticResource DangerButtonStyle}" Padding="12,8" Margin="0,0,8,0" Click="BtnResetLayout_Click"/>
                    <Button x:Name="BtnSaveLayout" Content="Save Layout" Style="{StaticResource AccentButtonStyle}" Padding="16,8" Click="BtnSaveLayout_Click"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Main Workspace Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Left: Canvas Area -->
                <ColumnDefinition Width="*"/>
                <!-- Right: Properties Inspector Panel -->
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- The Visual Screen Canvas Container -->
            <Border Grid.Column="0" Margin="0,0,24,0" Background="#070708" BorderBrush="#262629" BorderThickness="1" CornerRadius="12" ClipToBounds="True" MouseLeftButtonDown="Canvas_MouseLeftButtonDown">
                <Grid>
                    <Grid.LayoutTransform>
                        <ScaleTransform x:Name="CanvasScale" ScaleX="1.0" ScaleY="1.0"/>
                    </Grid.LayoutTransform>
                    <!-- Visual Grid Backdrop Pattern -->
                    <Grid.Background>
                        <VisualBrush TileMode="Tile" Viewport="0,0,20,20" ViewportUnits="Absolute">
                            <VisualBrush.Visual>
                                <Path Data="M 0,0 L 0,20 M 0,0 L 20,0" Stroke="#161619" StrokeThickness="1"/>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Grid.Background>

                    <!-- Center Crosshair Marker -->
                    <Ellipse Width="8" Height="8" Fill="#1C1C1F" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <!-- Alignment Guides -->
                    <Line x:Name="GuideVertical" Stroke="#0A84FF" StrokeThickness="1" StrokeDashArray="2,2" Visibility="Collapsed" X1="0" Y1="0" X2="0" Y2="0"/>
                    <Line x:Name="GuideHorizontal" Stroke="#0A84FF" StrokeThickness="1" StrokeDashArray="2,2" Visibility="Collapsed" X1="0" Y1="0" X2="0" Y2="0"/>

                    <!-- Drag Help Tip -->
                    <TextBlock Text="Drag shortcuts to arrange them. Hold Alt to temporarily disable grid snapping." 
                               Foreground="#333336" FontSize="11" FontWeight="SemiBold"
                               HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,16" IsHitTestVisible="False"/>
                    
                    <!-- Items Canvas container -->
                    <ItemsControl x:Name="EditorItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas x:Name="EditorCanvas" Background="Transparent"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left">
                                    <Setter.Value>
                                        <MultiBinding Converter="{StaticResource PercentConverter}" ConverterParameter="40">
                                            <Binding Path="X"/>
                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Canvas}"/>
                                        </MultiBinding>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Canvas.Top">
                                    <Setter.Value>
                                        <MultiBinding Converter="{StaticResource PercentConverter}" ConverterParameter="40">
                                            <Binding Path="Y"/>
                                            <Binding Path="ActualHeight" RelativeSource="{RelativeSource AncestorType=Canvas}"/>
                                        </MultiBinding>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ItemsControl.ItemContainerStyle>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Interactive Draggable Card -->
                                <Border MouseLeftButtonDown="Card_MouseLeftButtonDown"
                                        MouseMove="Card_MouseMove"
                                        MouseLeftButtonUp="Card_MouseLeftButtonUp"
                                        Cursor="SizeAll"
                                        Background="{Binding VisualStyle.BackgroundBrush}"
                                        BorderBrush="{Binding VisualStyle.BorderBrush}">
                                    <Grid>
                                        <Grid Margin="4,6,4,4">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            
                                            <!-- Rounded Icon Well -->
                                            <Border Grid.Row="0" Width="28" Height="28" CornerRadius="8" 
                                                    Background="{Binding VisualStyle.IconWellBrush}" 
                                                    BorderBrush="{Binding VisualStyle.BorderBrush}" 
                                                    BorderThickness="1" 
                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Grid>
                                                    <!-- Fallback Text (only visible if ResolvedIcon is null) -->
                                                    <TextBlock x:Name="FallbackIconText" Text="{Binding FallbackText}" 
                                                               Foreground="{Binding VisualStyle.BadgeTextBrush}" 
                                                               FontSize="10" FontWeight="Bold"
                                                               FontFamily="Segoe UI, Segoe MDL2 Assets, Arial"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ResolvedIcon}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>

                                                    <!-- Real app/file/folder/favicon image -->
                                                    <Image x:Name="RealIconImage" Source="{Binding ResolvedIcon}" Width="18" Height="18" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <Trigger Property="Source" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                </Grid>
                                            </Border>
 
                                            <TextBlock Grid.Row="1" Text="{Binding Title}" Foreground="#F3F3F3" FontSize="10" FontWeight="SemiBold"
                                                       TextAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                                        </Grid>
                                    </Grid>
                                    <Border.Style>
                                        <!-- Selection indicator triggers -->
                                        <Style TargetType="Border" BasedOn="{StaticResource EditorCardStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BorderBrush" Value="#0A84FF"/>
                                                    <Setter Property="Background" Value="#132235"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- Right: Properties Inspector Panel -->
            <Border Grid.Column="1" Background="#131315" BorderBrush="#262629" BorderThickness="1" CornerRadius="12" Padding="20">
                <Grid>
                    <!-- Form Container -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,0,-8,0" Padding="0,0,8,0">
                        <Grid>
                            
                            <!-- Selected Shortcut Inspector -->
                            <StackPanel x:Name="PropertiesFormPanel" Visibility="Collapsed">
                                
                                <!-- Inspector Header -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Border Width="36" Height="36" Background="#1C1C1F" BorderBrush="#262629" BorderThickness="1" CornerRadius="8" Margin="0,0,12,0" VerticalAlignment="Center">
                                        <TextBlock x:Name="TxtInspectorIcon" Text="S" Foreground="#0A84FF" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Properties" Foreground="#F3F3F3" FontSize="14" FontWeight="Bold"/>
                                        <TextBlock Text="Selected shortcut details" Foreground="#8E8E93" FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>

                                <Border Height="1" Background="#262629" Margin="0,0,0,16"/>                                 <!-- SECTION 1: Shortcut Details -->
                                <TextBlock Text="Shortcut Details" Foreground="#F3F3F3" FontSize="12" FontWeight="Bold" Margin="0,0,0,12"/>
                                
                                <TextBlock Text="Title" Foreground="#8E8E93" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                <TextBox x:Name="TxtTitle" Padding="8" Margin="0,0,0,14" TextChanged="TxtTitle_TextChanged" GotFocus="InspectorField_GotFocus"/>
        
                                <TextBlock Text="Shortcut Type" Foreground="#8E8E93" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                <ComboBox x:Name="ComboType" Padding="8" Margin="0,0,0,16" SelectionChanged="ComboType_SelectionChanged" GotFocus="InspectorField_GotFocus">
                                    <ComboBoxItem Content="App (.exe)"/>
                                    <ComboBoxItem Content="Folder"/>
                                    <ComboBoxItem Content="File"/>
                                    <ComboBoxItem Content="Website (URL)"/>
                                    <ComboBoxItem Content="System Action"/>
                                </ComboBox>
        
                                <Border Height="1" Background="#262629" Margin="0,4,0,16"/>
 
                                <!-- SECTION 2: Target path/arguments -->
                                <TextBlock Text="Target" Foreground="#F3F3F3" FontSize="12" FontWeight="Bold" Margin="0,0,0,12"/>
 
                                <TextBlock x:Name="LblTarget" Text="Target Path / URL" Foreground="#8E8E93" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtTarget" Grid.Column="0" Padding="8" TextChanged="TxtTarget_TextChanged" GotFocus="InspectorField_GotFocus"/>
                                    <Button x:Name="BtnBrowse" Grid.Column="1" Content="..." Style="{StaticResource DefaultButtonStyle}" Width="36" Margin="6,0,0,0" Click="BtnBrowse_Click"/>
                                </Grid>
        
                                <TextBlock x:Name="LblArguments" Text="Arguments (Optional)" Foreground="#8E8E93" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                <TextBox x:Name="TxtArguments" Padding="8" Margin="0,0,0,16" TextChanged="TxtArguments_TextChanged" GotFocus="InspectorField_GotFocus"/>
        
                                <Border Height="1" Background="#262629" Margin="0,4,0,16"/>
 
                                <!-- SECTION 3: Position on Canvas -->
                                <Expander Header="Position on canvas" Foreground="#F3F3F3" FontSize="12" FontWeight="Bold" IsExpanded="True" BorderThickness="0" Background="Transparent" Padding="0">
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                            <TextBlock Text="X Position" Foreground="#8E8E93" FontSize="10" FontWeight="Bold"/>
                                            <TextBox x:Name="TxtCoordX" Background="#1C1C1F" BorderBrush="#262629" Foreground="#8E8E93" Padding="6" Margin="0,4,0,0" FontSize="12" TextChanged="TxtCoordX_TextChanged" GotFocus="InspectorField_GotFocus"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                            <TextBlock Text="Y Position" Foreground="#8E8E93" FontSize="10" FontWeight="Bold"/>
                                            <TextBox x:Name="TxtCoordY" Background="#1C1C1F" BorderBrush="#262629" Foreground="#8E8E93" Padding="6" Margin="0,4,0,0" FontSize="12" TextChanged="TxtCoordY_TextChanged" GotFocus="InspectorField_GotFocus"/>
                                        </StackPanel>
                                    </Grid>
                                </Expander>

                                <Border Height="1" Background="#262629" Margin="0,20"/>
        
                                <!-- SECTION 4: Danger Zone -->
                                <Border Background="#1C1414" BorderBrush="#4C1A1A" BorderThickness="1" CornerRadius="10" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="Danger Zone" Foreground="#FF453A" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <TextBlock Text="Deleting this shortcut will permanently remove it from the canvas layout." Foreground="#8E8E93" FontSize="10" TextWrapping="Wrap" LineHeight="14" Margin="0,0,0,12"/>
                                        <Button x:Name="BtnDelete" Content="Delete Shortcut" Style="{StaticResource DangerButtonStyle}" Padding="8" Click="BtnDelete_Click"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Empty Inspector State -->
                            <StackPanel x:Name="NoSelectionPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,80,0,0">
                                <TextBlock Text="No Shortcut Selected" Foreground="#F3F3F3" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <TextBlock Text="Select a card on the canvas to edit its details and actions." Foreground="#8E8E93" FontSize="11" TextAlignment="Center" Width="200" TextWrapping="Wrap" LineHeight="16" Margin="0,0,0,24"/>
                                <Button Content="+ Add Shortcut" Style="{StaticResource DefaultButtonStyle}" Padding="12,8" HorizontalAlignment="Center" Click="BtnAdd_Click"/>
                            </StackPanel>
                            
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
