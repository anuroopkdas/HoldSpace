<Window x:Class="HoldSpace.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HoldSpace"
        mc:Ignorable="d"
        Title="Welcome to HoldSpace" Height="500" Width="760" Icon="app_icon.ico"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <!-- Onboarding Custom Toggle Card Style -->
        <Style x:Key="OnboardingCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#1C1C1F"/>
            <Setter Property="BorderBrush" Value="#262629"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#3A3A3D"/>
                    <Setter Property="Background" Value="#252528"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="#0C0C0D" BorderBrush="#262629" BorderThickness="1" CornerRadius="12">
        <Grid Margin="24">
        <Grid.RowDefinitions>
            <!-- Header bar with logo -->
            <RowDefinition Height="Auto"/>
            <!-- Slide Views -->
            <RowDefinition Height="*"/>
            <!-- Progress & Footer buttons -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header / Logo -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock Text="Hold" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="Bold"/>
                <TextBlock Text="Space" Foreground="{StaticResource AccentBrush}" FontSize="16" FontWeight="Bold"/>
            </StackPanel>
            <TextBlock Text="Onboarding" Foreground="{StaticResource TextSecondary}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>

        <Border Grid.Row="0" Height="1" Background="#262629" Margin="0,28,0,0"/>

        <!-- Main Slide TabControl (Hidden headers) -->
        <TabControl x:Name="TabOnboarding" Grid.Row="1" Style="{StaticResource HiddenTabControl}" SelectedIndex="0" Background="Transparent" BorderThickness="0" Margin="0,16">
            
            <!-- Slide 0: Welcome -->
            <TabItem>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="Welcome to HoldSpace" Foreground="#F3F3F3" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="Hold a key to reveal your canvas. Hover over an item, release the key, and launch instantly." 
                                   Foreground="#8E8E93" FontSize="13" TextWrapping="Wrap" LineHeight="20" Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- Gesture Diagram -->
                    <Border Grid.Row="1" Background="#131315" BorderBrush="#262629" BorderThickness="1" CornerRadius="10" Padding="20" VerticalAlignment="Center">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <Border Width="40" Height="40" CornerRadius="20" Background="#1C1C1F" BorderBrush="#262629" BorderThickness="1" Margin="0,0,0,8">
                                    <TextBlock Text="⌨" Foreground="#0A84FF" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="1. Hold Key" Foreground="#F3F3F3" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Grid.Column="1" Text="→" Foreground="#8E8E93" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <Border Width="40" Height="40" CornerRadius="20" Background="#1C1C1F" BorderBrush="#262629" BorderThickness="1" Margin="0,0,0,8">
                                    <TextBlock Text="🖲" Foreground="#0A84FF" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="2. Hover Mouse" Foreground="#F3F3F3" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Grid.Column="3" Text="→" Foreground="#8E8E93" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                <Border Width="40" Height="40" CornerRadius="20" Background="#1C1C1F" BorderBrush="#262629" BorderThickness="1" Margin="0,0,0,8">
                                    <TextBlock Text="🚀" Foreground="#0A84FF" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="3. Release to Launch" Foreground="#F3F3F3" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Slide 1: Choose Trigger -->
            <TabItem>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="Choose your hold trigger" Foreground="#F3F3F3" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="This is the key or button you'll hold down to reveal HoldSpace." Foreground="#8E8E93" FontSize="13" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <!-- Key Options Dropdown -->
                        <TextBlock Text="Trigger Source" Foreground="#8E8E93" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                        <ComboBox x:Name="ComboTriggerSource" Padding="10,8" Margin="0,0,0,16" SelectionChanged="ComboTriggerSource_SelectionChanged">
                            <ComboBoxItem Content="Caps Lock (Recommended)"/>
                            <ComboBoxItem Content="Left Alt"/>
                            <ComboBoxItem Content="Right Alt"/>
                            <ComboBoxItem Content="Mouse Button 4 (XButton1)"/>
                            <ComboBoxItem Content="Mouse Button 5 (XButton2)"/>
                            <ComboBoxItem Content="Custom Keyboard Key..."/>
                        </ComboBox>

                        <!-- Custom Key Recorder Panel -->
                        <Grid x:Name="CustomKeyPanel" Visibility="Collapsed" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Custom Key Trigger" Foreground="#F3F3F3" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Press Record and tap any keyboard key" Foreground="#8E8E93" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button x:Name="BtnRecordOnboarding" Grid.Column="1" Content="Record Key" Style="{StaticResource DefaultButtonStyle}" Width="140" Click="BtnRecordOnboarding_Click"/>
                        </Grid>

                        <!-- Key Warning Box -->
                        <Border x:Name="WinKeyWarningOnboarding" Background="#2C1616" BorderBrush="#FF453A" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,8,0,0" Visibility="Collapsed">
                            <TextBlock Text="The Windows key is reserved by the OS and is not recommended. Use custom keys or Alt for a reliable experience." 
                                       Foreground="#FF453A" FontSize="11" TextWrapping="Wrap" LineHeight="16"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Slide 2: Test Gesture -->
            <TabItem>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="Try the gesture" Foreground="#F3F3F3" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="Practice the HoldSpace workflow. Let's make sure the hook and overlay capture work properly on your system." 
                                   Foreground="#8E8E93" FontSize="13" TextWrapping="Wrap" LineHeight="20" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Test Area Panel -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <Border Background="#131315" BorderBrush="#262629" BorderThickness="1" CornerRadius="10" Padding="20">
                            <StackPanel>
                                <TextBlock x:Name="TxtTestStatus" Text="Instructions:" Foreground="#F3F3F3" FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>
                                
                                <TextBlock x:Name="TxtTestInstructions" Text="1. PRESS AND HOLD your selected trigger key now.&#x0a;2. Hover your mouse over the demo cards (Browser, Folder, or Settings).&#x0a;3. RELEASE the key over one of the items." 
                                           Foreground="#8E8E93" FontSize="12" TextWrapping="Wrap" LineHeight="18"/>
                                
                                <!-- Success indicator -->
                                <Border x:Name="TestSuccessBanner" Background="#112C1B" BorderBrush="#30D158" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,16,0,0" Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="✔" Foreground="#30D158" FontSize="16" FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtTestSuccess" Text="Perfect. That's the HoldSpace gesture." Foreground="#30D158" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Slide 3: Add First Shortcuts -->
            <TabItem>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Add your first shortcuts" Foreground="#F3F3F3" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="Select folder path or website shortcuts to pre-populate your launcher canvas." Foreground="#8E8E93" FontSize="13" Margin="0,4,0,0"/>
                    </StackPanel>
                    <!-- Bento Layout Grid -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <!-- Core Windows (Left) -->
                            <ColumnDefinition Width="1*"/>
                            <!-- System Utilities (Middle) -->
                            <ColumnDefinition Width="1.2*"/>
                            <!-- Weblinks (Right) -->
                            <ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Core Windows -->
                        <Border Grid.Column="0" Background="#131315" BorderBrush="#262629" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,6,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="CORE WINDOWS" Foreground="#8E8E93" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="1" VerticalAlignment="Top">
                                    <!-- Downloads -->
                                    <Border Style="{StaticResource OnboardingCardStyle}" Margin="0,0,0,6" MouseLeftButtonDown="ShortcutCard_Click">
                                        <CheckBox x:Name="ChkDownloads" Style="{StaticResource ToggleSwitchStyle}" Content="Downloads Folder" IsChecked="True"/>
                                    </Border>
                                    <!-- Documents -->
                                    <Border Style="{StaticResource OnboardingCardStyle}" Margin="0,0,0,6" MouseLeftButtonDown="ShortcutCard_Click">
                                        <CheckBox x:Name="ChkDocuments" Style="{StaticResource ToggleSwitchStyle}" Content="Documents Folder" IsChecked="False"/>
                                    </Border>
                                    <!-- Desktop -->
                                    <Border Style="{StaticResource OnboardingCardStyle}" MouseLeftButtonDown="ShortcutCard_Click">
                                        <CheckBox x:Name="ChkDesktop" Style="{StaticResource ToggleSwitchStyle}" Content="Desktop Folder" IsChecked="False"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- System Utilities -->
                        <Border Grid.Column="1" Background="#131315" BorderBrush="#262629" BorderThickness="1" CornerRadius="8" Padding="12" Margin="6,0,6,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="SYSTEM UTILITIES" Foreground="#8E8E93" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <StackPanel VerticalAlignment="Top">
                                        <!-- Task Manager -->
                                        <Border Style="{StaticResource OnboardingCardStyle}" Margin="0,0,0,6" MouseLeftButtonDown="ShortcutCard_Click">
                                            <CheckBox x:Name="ChkTaskManager" Style="{StaticResource ToggleSwitchStyle}" Content="Task Manager" IsChecked="True"/>
                                        </Border>
                                        <!-- Command Prompt -->
                                        <Border Style="{StaticResource OnboardingCardStyle}" Margin="0,0,0,6" MouseLeftButtonDown="ShortcutCard_Click">
                                            <CheckBox x:Name="ChkTerminal" Style="{StaticResource ToggleSwitchStyle}" Content="Command Prompt" IsChecked="False"/>
                                        </Border>
                                        <!-- PowerShell -->
                                        <Border Style="{StaticResource OnboardingCardStyle}" Margin="0,0,0,6" MouseLeftButtonDown="ShortcutCard_Click">
                                            <CheckBox x:Name="ChkPowerShell" Style="{StaticResource ToggleSwitchStyle}" Content="PowerShell" IsChecked="False"/>
                                        </Border>
                                        <!-- Snipping Tool -->
                                        <Border Style="{StaticResource OnboardingCardStyle}" Margin="0,0,0,6" MouseLeftButtonDown="ShortcutCard_Click">
                                            <CheckBox x:Name="ChkSnippingTool" Style="{StaticResource ToggleSwitchStyle}" Content="Snipping Tool" IsChecked="False"/>
                                        </Border>
                                        <!-- Calculator -->
                                        <Border Style="{StaticResource OnboardingCardStyle}" Margin="0,0,0,6" MouseLeftButtonDown="ShortcutCard_Click">
                                            <CheckBox x:Name="ChkCalculator" Style="{StaticResource ToggleSwitchStyle}" Content="Calculator" IsChecked="False"/>
                                        </Border>
                                        <!-- Windows Settings -->
                                        <Border Style="{StaticResource OnboardingCardStyle}" Margin="0,0,0,6" MouseLeftButtonDown="ShortcutCard_Click">
                                            <CheckBox x:Name="ChkSettings" Style="{StaticResource ToggleSwitchStyle}" Content="System Settings" IsChecked="False"/>
                                        </Border>
                                        <!-- Control Panel -->
                                        <Border Style="{StaticResource OnboardingCardStyle}" MouseLeftButtonDown="ShortcutCard_Click">
                                            <CheckBox x:Name="ChkControlPanel" Style="{StaticResource ToggleSwitchStyle}" Content="Control Panel" IsChecked="False"/>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!-- Weblinks -->
                        <Border Grid.Column="2" Background="#131315" BorderBrush="#262629" BorderThickness="1" CornerRadius="8" Padding="12" Margin="6,0,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="WEBLINKS" Foreground="#8E8E93" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <StackPanel VerticalAlignment="Top">
                                        <!-- Google Search -->
                                        <Border Style="{StaticResource OnboardingCardStyle}" Margin="0,0,0,6" MouseLeftButtonDown="ShortcutCard_Click">
                                            <CheckBox x:Name="ChkGoogle" Style="{StaticResource ToggleSwitchStyle}" Content="Google Search" IsChecked="True"/>
                                        </Border>
                                        <!-- ChatGPT -->
                                        <Border Style="{StaticResource OnboardingCardStyle}" Margin="0,0,0,6" MouseLeftButtonDown="ShortcutCard_Click">
                                            <CheckBox x:Name="ChkChatGPT" Style="{StaticResource ToggleSwitchStyle}" Content="ChatGPT" IsChecked="False"/>
                                        </Border>
                                        <!-- GitHub -->
                                        <Border Style="{StaticResource OnboardingCardStyle}" Margin="0,0,0,6" MouseLeftButtonDown="ShortcutCard_Click">
                                            <CheckBox x:Name="ChkGitHub" Style="{StaticResource ToggleSwitchStyle}" Content="GitHub" IsChecked="False"/>
                                        </Border>
                                        <!-- StackOverflow -->
                                        <Border Style="{StaticResource OnboardingCardStyle}" Margin="0,0,0,6" MouseLeftButtonDown="ShortcutCard_Click">
                                            <CheckBox x:Name="ChkStackOverflow" Style="{StaticResource ToggleSwitchStyle}" Content="StackOverflow" IsChecked="False"/>
                                        </Border>
                                        <!-- Notion -->
                                        <Border Style="{StaticResource OnboardingCardStyle}" Margin="0,0,0,6" MouseLeftButtonDown="ShortcutCard_Click">
                                            <CheckBox x:Name="ChkNotion" Style="{StaticResource ToggleSwitchStyle}" Content="Notion" IsChecked="False"/>
                                        </Border>
                                        <!-- YouTube -->
                                        <Border Style="{StaticResource OnboardingCardStyle}" Margin="0,0,0,6" MouseLeftButtonDown="ShortcutCard_Click">
                                            <CheckBox x:Name="ChkYouTube" Style="{StaticResource ToggleSwitchStyle}" Content="YouTube" IsChecked="False"/>
                                        </Border>
                                        <!-- Google Drive -->
                                        <Border Style="{StaticResource OnboardingCardStyle}" Margin="0,0,0,6" MouseLeftButtonDown="ShortcutCard_Click">
                                            <CheckBox x:Name="ChkGoogleDrive" Style="{StaticResource ToggleSwitchStyle}" Content="Google Drive" IsChecked="False"/>
                                        </Border>
                                        <!-- Gmail -->
                                        <Border Style="{StaticResource OnboardingCardStyle}" Margin="0,0,0,6" MouseLeftButtonDown="ShortcutCard_Click">
                                            <CheckBox x:Name="ChkGmail" Style="{StaticResource ToggleSwitchStyle}" Content="Gmail" IsChecked="False"/>
                                        </Border>
                                        <!-- Slack -->
                                        <Border Style="{StaticResource OnboardingCardStyle}" Margin="0,0,0,6" MouseLeftButtonDown="ShortcutCard_Click">
                                            <CheckBox x:Name="ChkSlack" Style="{StaticResource ToggleSwitchStyle}" Content="Slack" IsChecked="False"/>
                                        </Border>
                                        <!-- Figma -->
                                        <Border Style="{StaticResource OnboardingCardStyle}" MouseLeftButtonDown="ShortcutCard_Click">
                                            <CheckBox x:Name="ChkFigma" Style="{StaticResource ToggleSwitchStyle}" Content="Figma" IsChecked="False"/>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Slide 4: Finish -->
            <TabItem>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="You're ready!" Foreground="#F3F3F3" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="Hold your trigger key anytime to reveal the launcher overlay." Foreground="#8E8E93" FontSize="13" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Summary Stats Card -->
                    <Border Grid.Row="1" Background="#131315" BorderBrush="#262629" BorderThickness="1" CornerRadius="10" Padding="20" VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="SETUP SUMMARY" Foreground="#8E8E93" FontSize="11" FontWeight="Bold" Margin="0,0,0,16"/>

                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="Hold Trigger Key:" Foreground="#8E8E93" FontSize="13"/>
                                <TextBlock x:Name="TxtSummaryTrigger" Text="Caps Lock" Foreground="#0A84FF" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="Shortcuts Created:" Foreground="#8E8E93" FontSize="13"/>
                                <TextBlock x:Name="TxtSummaryShortcuts" Text="0 items" Foreground="#F3F3F3" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>

                            <Border Height="1" Background="#262629" Margin="0,8,0,12"/>

                            <TextBlock Text="Tip: You can customize layouts, toggle dim levels, or configure alternative hotkeys at any time inside the HoldSpace Dashboard." 
                                       Foreground="#8E8E93" FontSize="11" TextWrapping="Wrap" LineHeight="16"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Footer / Navigation Progress & Buttons -->
        <Border Grid.Row="2" BorderBrush="#262629" BorderThickness="0,1,0,0" Padding="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left Action Buttons -->
                <Button x:Name="BtnBack" Grid.Column="0" Content="Back" Style="{StaticResource DefaultButtonStyle}" Width="80" Click="BtnBack_Click" Visibility="Collapsed"/>
                <Button x:Name="BtnSkipWelcome" Grid.Column="0" Content="Skip Setup" Style="{StaticResource DefaultButtonStyle}" Width="95" Click="BtnSkipWelcome_Click"/>

                <!-- Middle Progress Dots -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse x:Name="Dot0" Width="8" Height="8" Fill="#0A84FF" Margin="4,0"/>
                    <Ellipse x:Name="Dot1" Width="8" Height="8" Fill="#2C2C2E" Margin="4,0"/>
                    <Ellipse x:Name="Dot2" Width="8" Height="8" Fill="#2C2C2E" Margin="4,0"/>
                    <Ellipse x:Name="Dot3" Width="8" Height="8" Fill="#2C2C2E" Margin="4,0"/>
                    <Ellipse x:Name="Dot4" Width="8" Height="8" Fill="#2C2C2E" Margin="4,0"/>
                </StackPanel>

                <!-- Right Action Buttons -->
                <Button x:Name="BtnContinue" Grid.Column="2" Content="Continue" Style="{StaticResource AccentButtonStyle}" Width="100" Click="BtnContinue_Click"/>
                <Button x:Name="BtnFinish" Grid.Column="2" Content="Open HoldSpace" Style="{StaticResource AccentButtonStyle}" Width="140" Click="BtnFinish_Click" Visibility="Collapsed"/>
            </Grid>
        </Border>
    </Grid>
    </Border>
</Window>
