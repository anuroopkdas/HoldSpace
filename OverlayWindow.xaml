<Window x:Class="HoldSpace.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:HoldSpace.Converters"
        mc:Ignorable="d"
        Title="HoldSpace Overlay" Height="1080" Width="1920"
        WindowStyle="None" AllowsTransparency="True" Background="#E5070708"
        Topmost="True" ShowInTaskbar="False" WindowState="Normal" ResizeMode="NoResize"
        ShowActivated="False">
    
    <Window.Resources>
        <converters:PercentageToAbsoluteConverter x:Key="PercentConverter"/>

        <!-- Premium Rounded Cards for Fullscreen Overlay -->
        <Style x:Key="ShortcutCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#131315"/>
            <Setter Property="BorderBrush" Value="#262629"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="120"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="2" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="OverlayGrid">
        <!-- Overlay Canvas -->
        <ItemsControl x:Name="ShortcutsItemsControl">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas x:Name="OverlayCanvas" Background="Transparent"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Canvas.Left">
                        <Setter.Value>
                            <MultiBinding Converter="{StaticResource PercentConverter}" ConverterParameter="60">
                                <Binding Path="X"/>
                                <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Canvas}"/>
                            </MultiBinding>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Canvas.Top">
                        <Setter.Value>
                            <MultiBinding Converter="{StaticResource PercentConverter}" ConverterParameter="60">
                                <Binding Path="Y"/>
                                <Binding Path="ActualHeight" RelativeSource="{RelativeSource AncestorType=Canvas}"/>
                            </MultiBinding>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ItemsControl.ItemContainerStyle>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource ShortcutCardStyle}" 
                            Background="{Binding VisualStyle.BackgroundBrush}"
                            BorderBrush="{Binding VisualStyle.BorderBrush}"
                            MouseEnter="Card_MouseEnter" 
                            MouseLeave="Card_MouseLeave"
                            Cursor="Hand">
                        <Grid>
                            <!-- Main Layout Grid -->
                            <Grid Margin="0,4,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Rounded Icon Well -->
                                <Border Grid.Row="0" Width="48" Height="48" CornerRadius="12" 
                                        Background="{Binding VisualStyle.IconWellBrush}" 
                                        BorderBrush="{Binding VisualStyle.BorderBrush}" 
                                        BorderThickness="1" 
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid>
                                        <!-- Fallback Text (only visible if ResolvedIcon is null) -->
                                        <TextBlock x:Name="FallbackIconText" Text="{Binding FallbackText}" 
                                                   Foreground="{Binding VisualStyle.BadgeTextBrush}" 
                                                   FontSize="18" FontWeight="Bold"
                                                   FontFamily="Segoe UI, Segoe MDL2 Assets, Arial"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ResolvedIcon}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- Real app/file/folder/favicon image -->
                                        <Image x:Name="RealIconImage" Source="{Binding ResolvedIcon}" Width="28" Height="28" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="Source" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                    </Grid>
                                </Border>

                                <!-- Title and Badge -->
                                <StackPanel Grid.Row="1" Margin="0,6,0,0">
                                    <TextBlock Text="{Binding Title}" Foreground="#F3F3F3" FontSize="11" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    
                                    <!-- Category Badge -->
                                    <TextBlock Text="{Binding VisualStyle.CategoryName}" Foreground="{Binding VisualStyle.BadgeTextBrush}" 
                                               FontSize="8" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Empty State Message -->
        <TextBlock x:Name="EmptyStateText" Text="No shortcuts added yet. Open HoldSpace Dashboard to add your first shortcut!&#x0a;&#x0a;[Hold Caps Lock and press Esc to close]" 
                   Foreground="#8E8E93" FontSize="18" FontWeight="SemiBold" TextAlignment="Center" LineHeight="28"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>

        <!-- Dynamic Indicator footer pill -->
        <Border VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,48" 
                Background="#CC131315" BorderBrush="#262629" BorderThickness="1" CornerRadius="18" Padding="18,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="HelperText" Text="Release to launch  •  Esc to cancel" Foreground="#8E8E93" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Border x:Name="HoverIndicator" Visibility="Collapsed" Margin="8,0,0,0" Padding="8,2" CornerRadius="4" Background="#1D2A3A" BorderBrush="#0A84FF" BorderThickness="0.5">
                    <TextBlock x:Name="HoveredItemText" Text="None" Foreground="#0A84FF" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
